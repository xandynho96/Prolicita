# Connection string do Neon (Postgres). Crie um projeto em https://neon.tech
DATABASE_URL="postgresql://usuario:senha@ep-xxxx.neon.tech/prolicita?sslmode=require"

# Segredo do NextAuth — gere com: openssl rand -base64 32
AUTH_SECRET=""

# Login com Google — crie um OAuth Client ID em
# https://console.cloud.google.com/apis/credentials (tipo "Web application").
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# (troque pelo domínio de produção quando fizer o deploy).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Chave da API DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=""

# Sua instância existente do Evolution API
EVOLUTION_API_URL="https://sua-instancia-evolution.com"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE="nome-da-instancia"

# Segredo para proteger o endpoint de cron (/api/cron/buscar-licitacoes).
# A Vercel envia automaticamente "Authorization: Bearer $CRON_SECRET" nos cron jobs
# quando essa variável está definida no projeto.
CRON_SECRET=""
